$desc = $($_.Text)
try {
	Write-Host "Ocultando: " -ForegroundColor Green -NoNewline
	Write-Host "$desc en el men� Contextual del Explorador de Archivos." -ForegroundColor Gray

	$keys = @(
		@{Path = "HKCR\Directory\background\shell\runas"; Name = ""; Value = ""; Type = ""; Action = "Delete"},
		@{Path = "HKCR\LibraryFolder\background\shell\runas"; Name = ""; Value = ""; Type = ""; Action = "Delete"},
		@{Path = "HKCR\Directory\background\shell\runasPS"; Name = ""; Value = ""; Type = ""; Action = "Delete"},
		@{Path = "HKCR\LibraryFolder\background\shell\runasPS"; Name = ""; Value = ""; Type = ""; Action = "Delete"}
	)

	foreach ($key in $keys) {
		Manage-Registration-Keys -path $key.Path -name $key.Name -value $key.Value -type $key.Type -action $key.Action
	}

	Remove-Item "C:\Windows\System32\AbrirPowerShellAdmin.vbs" -Force
}
catch {
	Write-Host "Error: " -ForegroundColor Red -NoNewline
	Write-Host "No se puedo ocultar $desc en el men� Contextual del Explorador de Archivos." -ForegroundColor Gray
}
